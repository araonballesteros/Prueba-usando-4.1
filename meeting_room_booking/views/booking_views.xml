<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Vista de lista para las reservas -->
    <record id="view_meeting_booking_tree" model="ir.ui.view">
        <field name="name">meeting.booking.tree</field>
        <field name="model">meeting.booking</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="room_id"/>
                <field name="booked_by"/>
                <field name="start_time"/>
                <field name="end_time"/>
            </tree>
        </field>
    </record>

    <!-- Vista de formulario para las reservas -->
    <record id="view_meeting_booking_form" model="ir.ui.view">
        <field name="name">meeting.booking.form</field>
        <field name="model">meeting.booking</field>
        <field name="arch" type="xml">
            <form string="Reserva de Sala">
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="room_id"/>
                        <field name="booked_by"/>
                        <field name="start_time"/>
                        <field name="end_time"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
