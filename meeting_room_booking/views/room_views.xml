<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Vista de lista para las salas de reuniones -->
    <record id="view_meeting_room_tree" model="ir.ui.view">
        <field name="name">meeting.room.tree</field>
        <field name="model">meeting.room</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="capacity"/>
                <field name="location"/>
                <field name="availability"/>
            </tree>
        </field>
    </record>

    <!-- Vista de formulario para las salas de reuniones -->
    <record id="view_meeting_room_form" model="ir.ui.view">
        <field name="name">meeting.room.form</field>
        <field name="model">meeting.room</field>
        <field name="arch" type="xml">
            <form string="Sala de Reuniones">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="capacity"/>
                        <field name="location"/>
                        <field name="availability"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
